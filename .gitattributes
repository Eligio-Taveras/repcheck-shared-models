# Default: detect text files, normalize them to LF in the working tree.
# Survives `git config core.autocrlf=true` on a developer's machine.
* text=auto eol=lf

# Windows-only scripts must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries: never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.jar   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
